def write_sop(service_id, sop_type, body, tags=None, host_id=None):
    _ensure_dirs()
    name = _svc_name(service_id)
    today = date.today().isoformat()

    if not host_id:
        data = _topo_data()
        for s in data.get("services", []):
            if s["id"] == service_id:
                host_id = s.get("deploys_on", "")
                break

    tag_list = [sop_type]
    if tags:
        tag_list.extend(t.strip() for t in tags.split(",") if t.strip())
    tags_yaml = "\n".join(f"  - {t}" for t in tag_list)

    content = SOP_TEMPLATE.format(
        title=f"{name} {sop_type} SOP",
        doc_type="sop",
        service_id=service_id,
        service_name=name,
        sop_type=sop_type,
        host_id=host_id or service_id,
        date=today,
        body=body,
    )
    content = content.replace(f"  - {sop_type}", tags_yaml)

    dirpath = os.path.join(SERVICES_DIR, f"{service_id}-{name}")
    os.makedirs(dirpath, exist_ok=True)
    fname = f"sop-{sop_type.replace(' ', '-')}.md"
    path = os.path.join(dirpath, fname)
    with open(path, "w") as f:
        f.write(content)
    print(f"SOP 写入: {path}")
    _index()


def write_tech(service_id, body, tags=None):
    _ensure_dirs()
    name = _svc_name(service_id)
    today = date.today().isoformat()

    if not tags:
        tags = "技术文档"
    tags_yaml = "\n".join(f"  - {t.strip()}" for t in tags.split(",") if t.strip())

    content = TECH_TEMPLATE.format(
        title=f"{name} 技术架构",
        service_id=service_id,
        service_name=name,
        tags="{tags_placeholder}",
        date=today,
        body=body,
    )
    content = content.replace("tags: {tags_placeholder}", f"tags:\n{tags_yaml}")

    dirpath = os.path.join(SERVICES_DIR, f"{service_id}-{name}")
    os.makedirs(dirpath, exist_ok=True)
    path = os.path.join(dirpath, "tech-arch.md")
    with open(path, "w") as f:
        f.write(content)
    print(f"技术文档写入: {path}")
    _index()


def write_incident(service_id, body, tags=None, host_id=None):
    _ensure_dirs()
    name = _svc_name(service_id)
    today = date.today().isoformat()

    if not host_id:
        data = _topo_data()
        for s in data.get("services", []):
            if s["id"] == service_id:
                host_id = s.get("deploys_on", "")
                break

    # Infer related services from topology
    related = []
    data = _topo_data()
    for s in data.get("services", []):
        if s["id"] == service_id:
            for c in s.get("calls", []):
                related.append(c["target"])
            break
    # Also add services that call this one
    for s in data.get("services", []):
        for c in s.get("calls", []):
            if c.get("target") == service_id and s["id"] not in related:
                related.append(s["id"])

    # Merge default tags with user-supplied tags
    tag_set = ["故障", "复盘"]
    if tags:
        for t in tags.split(","):
            t = t.strip()
            if t and t not in tag_set:
                tag_set.append(t)
    tags_yaml = "\n".join(f"  - {t}" for t in tag_set)

    content = INCIDENT_TEMPLATE.format(
        title=f"{name} 故障复盘 - {today}",
        service_id=service_id,
        service_name=name,
        related_services=related if related else [""],
        host_id=host_id or service_id,
        date=today,
        body=body,
    )
    # Replace default tags block with merged tags
    default_tags = "  - 故障\n  - 复盘"
    content = content.replace(default_tags, tags_yaml)

    path = os.path.join(INCIDENTS_DIR, f"{today}-{name}.md")
    with open(path, "w") as f:
        f.write(content)
    print(f"故障记录写入: {path}")
    _index()


def add_service(args):
    svc_id = args.get("--id", "")
    svc_name = args.get("--name", "")
    svc_host = args.get("--host", "")
    if not svc_id or not svc_name or not svc_host:
        print("错误: --id --name --host 必填")
        sys.exit(1)

    data = _topo_data()
    if any(s["id"] == svc_id for s in data.get("services", [])):
        print(f"错误: service_id '{svc_id}' 已存在")
        sys.exit(1)
    if not any(h["id"] == svc_host for h in data.get("hosts", [])):
        print(f"警告: host '{svc_host}' 不存在于拓扑中，请先 add-host")

    entry = {"id": svc_id, "name": svc_name, "deploys_on": svc_host}

    ports = args.get("--port", "")
    if ports:
        entry["ports"] = [int(p) for p in ports.split(",") if p.strip()]

    calls = []
    call_strs = args.get("--call", [])
    if isinstance(call_strs, str):
        call_strs = [call_strs]
    for cs in call_strs:
        parts = cs.split(":")
        calls.append({
            "target": parts[0],
            "protocol": parts[1] if len(parts) > 1 else "tcp",
            "port": int(parts[2]) if len(parts) > 2 else 0,
        })
    if calls:
        entry["calls"] = calls

    data.setdefault("services", []).append(entry)
    _save_topo(data)
    _api_post("/reload-topology", {})
    print(f"服务已添加: {svc_id} ({svc_name}) -> host {svc_host}")
    # Create empty tech doc
    write_tech(svc_id, "（待填写）")


def delete_service(service_id):
    data = _topo_data()
    svcs = [s for s in data.get("services", []) if s["id"] == service_id]
    if not svcs:
        print(f"错误: service_id '{service_id}' 不存在")
        sys.exit(1)

    # Remove from topology
    data["services"] = [s for s in data["services"] if s["id"] != service_id]
    # Remove calls targeting this service
    for s in data["services"]:
        s["calls"] = [c for c in s.get("calls", []) if c["target"] != service_id]
    _save_topo(data)

    # Remove docs dir
    for svc in svcs:
        dirpath = os.path.join(SERVICES_DIR, f"{service_id}-{svc.get('name', service_id)}")
        if os.path.isdir(dirpath):
            shutil.rmtree(dirpath)
            print(f"文档目录已删除: {dirpath}")

    # Delete from ES
    doc_ids_to_clean = []
    try:
        from elasticsearch import Elasticsearch
        es = Elasticsearch("http://localhost:9200")
        # Get doc_ids before deleting
        resp = es.search(index="knowledge_base", body={
            "size": 100,
            "query": {"term": {"service_ids": service_id}},
            "_source": ["doc_id"],
        })
        for hit in resp["hits"]["hits"]:
            did = hit["_source"].get("doc_id", "")
            if did:
                doc_ids_to_clean.append(did)
        doc_ids_to_clean = list(set(doc_ids_to_clean))
        # Delete from ES
        es.delete_by_query(index="knowledge_base", body={"query": {"term": {"service_ids": service_id}}})
        print(f"ES 中 service_ids 含 {service_id} 的文档已删除")
    except ImportError:
        print("无法连接 ES（容器外部运行），跳过 ES 删除，仅清理文档和拓扑")

    # Cleanup Neo4j Document nodes via API
    for doc_id in doc_ids_to_clean:
        _api_post("/reload-topology", {})
        break  # reload-topology already wipes all, only call once
    if doc_ids_to_clean:
        print(f"Neo4j Document 节点已清理: {len(doc_ids_to_clean)} 个")
    _index()


def add_host(args):
    host_id = args.get("--id", "")
    host_name = args.get("--name", "")
    ip = args.get("--ip", "")
    os_name = args.get("--os", "")
    if not host_id or not host_name or not ip:
        print("错误: --id --name --ip 必填")
        sys.exit(1)

    data = _topo_data()
    if any(h["id"] == host_id for h in data.get("hosts", [])):
        print(f"错误: host_id '{host_id}' 已存在")
        sys.exit(1)
    if any(h.get("ip") == ip for h in data.get("hosts", [])):
        print(f"错误: IP '{ip}' 已被 {[h['id'] for h in data['hosts'] if h.get('ip')==ip]} 使用")
        sys.exit(1)

    entry = {"id": host_id, "name": host_name, "ip": ip}
    if os_name:
        entry["os"] = os_name
    data.setdefault("hosts", []).append(entry)
    _save_topo(data)
    _api_post("/reload-topology", {})
    print(f"主机已添加: {host_id} ({host_name}) {ip}")
    _index()


def update_node(label: str, node_id: str, key: str, value: str):
    """Update any node property via PATCH /node/{label}/{id}.
    Labels: Service, Host, Port, Document, Cluster."""
    import urllib.request, urllib.error
    # Auto-convert numeric values
    try:
        typed_value = int(value)
    except ValueError:
        typed_value = value
    payload = json.dumps({key: typed_value}).encode()
    req = urllib.request.Request(
        f"{API}/node/{label}/{node_id}",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="PATCH",
    )
    try:
        resp = urllib.request.urlopen(req, timeout=10)
        print(json.dumps(json.loads(resp.read()), indent=2, ensure_ascii=False))
    except urllib.error.HTTPError as e:
        print(f"错误: {e.code} — {e.read().decode()[:200]}")
        sys.exit(1)


