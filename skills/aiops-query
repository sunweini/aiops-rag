_TEMPLATE_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "templates")

def _load_template(name):
    """Load template from templates/<name>.md. Returns raw text."""
    path = os.path.join(_TEMPLATE_DIR, f"{name}.md")
    if not os.path.exists(path):
        print(f"警告: 模板文件不存在: {path}")
        return ""
    with open(path) as f:
        return f.read()

SOP_TEMPLATE = _load_template("sop")
TECH_TEMPLATE = _load_template("tech")
INCIDENT_TEMPLATE = _load_template("incident")


