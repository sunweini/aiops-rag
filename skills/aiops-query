if __name__ == "__main__":
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    cmd = sys.argv[1]
    try:
        if cmd == "query":
            query(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "topology":
            topology(sys.argv[2])
        elif cmd == "impact":
            impact(sys.argv[2])
        elif cmd == "path":
            graph_path(sys.argv[2], int(sys.argv[3]) if len(sys.argv) > 3 else 3)
        elif cmd == "circular":
            circular()
        elif cmd == "health":
            health()
        elif cmd == "metrics":
            metrics()
        elif cmd == "write-sop":
            _write_cmd(sys.argv, write_sop, 3)
        elif cmd == "write-tech":
            _write_cmd(sys.argv, write_tech, 2)
        elif cmd == "write-incident":
            _write_cmd(sys.argv, write_incident, 2)
        elif cmd == "add-service":
            args = {}
            i = 2
            while i < len(sys.argv):
                if sys.argv[i].startswith("--"):
                    key = sys.argv[i]
                    vals = []
                    i += 1
                    while i < len(sys.argv) and not sys.argv[i].startswith("--"):
                        vals.append(sys.argv[i])
                        i += 1
                    args[key] = vals[0] if len(vals) == 1 else vals
                else:
                    i += 1
            add_service(args)
        elif cmd == "delete-service":
            delete_service(sys.argv[2])
        elif cmd == "update-node":
            if len(sys.argv) < 6:
                print("用法: aiops-query update-node <Label> <node_id> <key> <value>")
                print("示例: aiops-query update-node Host host_nginx_01 os 'Ubuntu 22.04'")
                print("       aiops-query update-node Service svc_nginx status active")
                print("       aiops-query update-node Port 9200 protocol tcp")
                print("       aiops-query update-node Cluster svc_nginx_company vip 10.33.16.250")
                print("       aiops-query update-node Document svc_nginx_tech-arch title '新标题'")
                print("有效 Labels: Service, Host, Port, Document, Cluster")
                sys.exit(1)
            update_node(sys.argv[2], sys.argv[3], sys.argv[4], " ".join(sys.argv[5:]))
        elif cmd == "add-host":
            args = {}
            i = 2
            while i < len(sys.argv):
                if sys.argv[i].startswith("--"):
                    key = sys.argv[i]
                    vals = []
                    i += 1
                    while i < len(sys.argv) and not sys.argv[i].startswith("--"):
                        vals.append(sys.argv[i])
                        i += 1
                    args[key] = vals[0] if len(vals) == 1 else vals
                else:
                    i += 1
            add_host(args)
        elif cmd == "index":
            if len(sys.argv) > 2 and sys.argv[2] == "--full":
                index(full=True)
            else:
                index()
        elif cmd == "index-file":
            if len(sys.argv) < 3:
                print("用法: aiops-query index-file <relpath>")
                print("示例: aiops-query index-file services/svc_nginx_company-company-nginx-cluster/tech-arch.md")
                sys.exit(1)
            index_file(sys.argv[2])
        elif cmd == "cluster":
            cluster(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "service-docs":
            service_docs(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "doc-services":
            doc_services(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "host-docs":
            host_docs(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "doc-hosts":
            doc_hosts(sys.argv[2] if len(sys.argv) > 2 else "")
        elif cmd == "sync-health":
            sync_health()
        else:
            # Default: treat whole input as query
            query(" ".join(sys.argv[1:]))
    except Exception as e:
        import traceback
        traceback.print_exc()
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
