def sync_health():
    resp = urllib.request.urlopen(f"{API}/health/sync", timeout=30)
    r = json.loads(resp.read())
    print(f"ES ↔ Neo4j 同步状态: {r.get('status', 'unknown')}")
    print(f"  孤儿文档(Neo4j有ES无): {len(r.get('orphan_docs', []))}")
    print(f"  悬空引用(ES有Neo4j无): {len(r.get('dangling_doc_refs', []))}")
    print(f"  缺边(HAS_DOC指向不存在): {len(r.get('missing_doc_edges', []))}")
    print(f"  集群问题: {len(r.get('cluster_issues', []))}")
    print(f"  ES文档数: {r.get('stats', {}).get('es_docs', '?')}")
    print(f"  Neo4j文档数: {r.get('stats', {}).get('neo4j_docs', '?')}")
    if r.get('partial'):
        print("  (扫描部分完成，部分结果不完整)")


