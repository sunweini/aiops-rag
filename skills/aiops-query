def query(question):
    data = json.dumps({"query": question}).encode()
    req = urllib.request.Request(
        f"{API}/query",
        data=data,
        headers={"Content-Type": "application/json"},
    )
    resp = urllib.request.urlopen(req, timeout=60)
    print(json.loads(resp.read())["answer"])


