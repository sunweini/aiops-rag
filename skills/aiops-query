#!/usr/bin/env python3
"""AIOps RAG CLI — query + maintenance.

QUERY:
  aiops-query query 'nginx 502 排查'
  aiops-query topology svc_nginx
  aiops-query cluster svc_nginx
  aiops-query impact host_app_01
  aiops-query path svc_nginx 3
  aiops-query circular
  aiops-query service-docs svc_nginx
  aiops-query host-docs host_nginx_01
  aiops-query doc-services svc_nginx_tech-arch
  aiops-query doc-hosts svc_nginx_company_tech-arch
  aiops-query health
  aiops-query sync-health
  aiops-query metrics
  aiops-query update-node <Label> <node_id> <key> <value>

MAINTENANCE:
  aiops-query index                  # 增量索引
  aiops-query index --full           # 强制全量
  aiops-query index-file <relpath>   # 单文件索引
  aiops-query update-node <Label> <node_id> <key> <value>
  aiops-query write-sop <svc_id> <sop_type> [--file <path> | '<body>'] [--tags 'tag1,tag2']
  aiops-query write-tech <svc_id> [--file <path> | '<body>'] [--tags 'tag1,tag2']
  aiops-query write-incident <svc_id> [--file <path> | '<body>'] [--tags 'tag1,tag2']
  aiops-query add-service --id <svc_id> --name '<name>' --host <host_id> [--port <n>] [--call <target>:<proto>:<port>]
  aiops-query delete-service <svc_id>
  aiops-query add-host --id <host_id> --name '<name>' --ip <ip> [--os '<os>']
  aiops-query index
"""

import json
import os
import shutil
import sys
import urllib.request
from datetime import date

API = "http://localhost:8001/api/v1"


def _api_post(path: str, data: dict = None) -> dict:
    """POST JSON to RAG API, return parsed response."""
    body = json.dumps(data or {}).encode()
    req = urllib.request.Request(
        f"{API}{path}",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        resp = urllib.request.urlopen(req, timeout=60)
        return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        err = json.loads(e.read()) if e.fp else {"detail": str(e)}
        print(f"API error [{path}]: {err.get('detail', e)}", file=sys.stderr)
        sys.exit(1)

# --- project root detection ---
for _cand in [
    os.path.expanduser("~/.openclaw/workspace-shared/rag"),
    "/root/.openclaw/workspace-shared/rag"
]:
    if os.path.isdir(_cand):
        RAG_ROOT = _cand
        break
else:
    RAG_ROOT = os.getcwd()

WIKI_DIR = os.path.expanduser("~/.openclaw/workspace-shared/rag-wiki")
DOCS_DIR = WIKI_DIR
TOPO_FILE = os.path.join(DOCS_DIR, "topology", "call-graph.yml")
SERVICES_DIR = os.path.join(DOCS_DIR, "services")
INCIDENTS_DIR = os.path.join(DOCS_DIR, "incidents")


def _ensure_dirs():
    for d in [SERVICES_DIR, INCIDENTS_DIR, os.path.join(DOCS_DIR, "topology"), os.path.join(DOCS_DIR, "hosts")]:
        os.makedirs(d, exist_ok=True)


def _svc_name(service_id):
    """Get service name from topology or return service_id as fallback."""
    if os.path.exists(TOPO_FILE):
        import yaml
        with open(TOPO_FILE) as f:
            data = yaml.safe_load(f) or {}
        for s in data.get("services", []):
            if s["id"] == service_id:
                return s.get("name", service_id)
    return service_id


def _topo_data():
    import yaml
    if os.path.exists(TOPO_FILE):
        with open(TOPO_FILE) as f:
            return yaml.safe_load(f) or {"services": [], "hosts": []}
    return {"services": [], "hosts": []}


def _save_topo(data):
    import yaml
    os.makedirs(os.path.dirname(TOPO_FILE), exist_ok=True)
    with open(TOPO_FILE, "w") as f:
        yaml.dump(data, f, allow_unicode=True, default_flow_style=False, sort_keys=False)


def _parse_write_args(args, svc_pos):
    """Parse write command args supporting --file and --tags."""
    body = ""
    tags = None
    body_parts = []
    i = svc_pos + 1
    while i < len(args):
        if args[i] == "--file" and i + 1 < len(args):
            try:
                with open(args[i + 1], "r") as f:
                    body = f.read()
            except Exception as e:
                print(f"读取文件失败: {e}")
                sys.exit(1)
            i += 2
        elif args[i] == "--tags" and i + 1 < len(args):
            tags = args[i + 1]
            i += 2
        else:
            body_parts.append(args[i])
            i += 1
    if not body:
        body = " ".join(body_parts)
    return body, tags


def _index(full=False):
    """Incremental index or full rebuild via RAG API."""
    if full:
        _api_post("/reload-topology", {})
    _api_post("/index-all", {"full": full})


